{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "destiny2-activism-report",
  "main": "./.output/server/index.mjs",
  "compatibility_date": "2026-04-07",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./.output/public/"
  },
  "kv_namespaces": [
    {
      "binding": "TOKEN_KV",
      "id": "e7087228c0284344b4882baadb18444c"
    }
  ],
  "observability": {
    "enabled": true
  }
}